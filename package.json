{
  "name": "tldr-installer",
  "version": "0.20.0",
  "description": "TLDR installer \u2014 detects your AI coding agents and installs TLDR (verdict-first style enforcer) for each one.",
  "license": "MIT",
  "author": "jqbit",
  "homepage": "https://github.com/jqbit/TLDR",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jqbit/TLDR.git"
  },
  "bugs": {
    "url": "https://github.com/jqbit/TLDR/issues"
  },
  "bin": {
    "tldr": "./bin/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test tests/installer/*.test.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "skills/",
    "plugins/",
    "commands/",
    "dist/tldr.skill",
    "README.md",
    "LICENSE",
    "docs/INSTALL.md",
    "docs/legal/",
    ".github/SECURITY.md",
    ".github/CODE_OF_CONDUCT.md",
    ".github/CITATION.cff",
    "!**/__pycache__/**",
    "!**/*.pyc"
  ],
  "main": "./bin/install.js",
  "keywords": [
    "tldr",
    "ai-agents",
    "llm",
    "prompt-engineering",
    "agent-tools",
    "claude-code",
    "codex",
    "gemini",
    "opencode",
    "cursor",
    "token-reduction",
    "terse-output"
  ]
}
